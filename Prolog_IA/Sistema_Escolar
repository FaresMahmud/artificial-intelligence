disciplina(logica).
disciplina(programacao).
disciplina(banco_de_dados).

pre_requisito(logica, programacao).
pre_requisito(programacao, banco_de_dados).


nota(fares, logica, 8).
nota(zamba, programacao, 6).
nota(pedro, logica, 7).
nota(felipe, programacao, 9).


aprovado(Aluno, Disciplina) :-
    nota(Aluno, Disciplina, Nota),
    Nota >= 7.

reprovado(Aluno, Disciplina) :-
    nota(Aluno, Disciplina, Nota),
    Nota < 7.


pode_cursar(_, Disciplina) :-
    disciplina(Disciplina),
    \+ pre_requisito(_, Disciplina).


pode_cursar(Aluno, Disciplina) :-
    pre_requisito(Anterior, Disciplina),
    aprovado(Aluno, Anterior).
